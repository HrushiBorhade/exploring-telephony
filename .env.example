# ┌─────────────────────────────────────────────────────────────────┐
# │  LIVEKIT CLOUD — https://cloud.livekit.io                      │
# │  Create project → Settings → API Keys                          │
# └─────────────────────────────────────────────────────────────────┘

LIVEKIT_URL=wss://your-app.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────────────┐
# │  LIVEKIT SIP TRUNK (connected to Plivo)                         │
# │  Created via: lk sip outbound create                            │
# │  The trunk ID starts with ST_                                   │
# └─────────────────────────────────────────────────────────────────┘

LIVEKIT_SIP_TRUNK_ID=ST_xxxxxxxxxxxxx

# ┌─────────────────────────────────────────────────────────────────┐
# │  AWS S3 (recording storage)                                     │
# │  Create IAM user with S3 access or use ECS task role            │
# └─────────────────────────────────────────────────────────────────┘

S3_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_BUCKET=telephony-recordings
S3_REGION=us-east-1
# S3_ENDPOINT=                    # Only set for non-AWS S3 (R2, MinIO)
# S3_PUBLIC_URL=                  # Public URL base for recordings (defaults to S3 virtual-hosted URL)

# ┌─────────────────────────────────────────────────────────────────┐
# │  POSTGRES — local database                                      │
# │  Run: createdb telephony                                        │
# └─────────────────────────────────────────────────────────────────┘

DATABASE_URL=postgresql://user@localhost:5432/telephony

# ┌─────────────────────────────────────────────────────────────────┐
# │  SERVER                                                         │
# └─────────────────────────────────────────────────────────────────┘

PORT=8080
# NODE_ENV=production
# FRONTEND_URL=https://your-app.vercel.app

# ┌─────────────────────────────────────────────────────────────────┐
# │  REDIS — BullMQ job queue                                       │
# └─────────────────────────────────────────────────────────────────┘

REDIS_HOST=localhost
REDIS_PORT=6379

# ┌─────────────────────────────────────────────────────────────────┐
# │  GEMINI — audio transcription (STT)                             │
# │  https://aistudio.google.com/apikey                             │
# └─────────────────────────────────────────────────────────────────┘

GEMINI_API_KEY=your-gemini-api-key
